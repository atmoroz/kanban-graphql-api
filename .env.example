# Server
PORT=4001

# Auth
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=30m

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Realtime (optional): if set, subscriptions work across multiple instances
# Example: redis://default:<password>@<host>:<port>
REDIS_URL=

# Email provider
EMAIL_PROVIDER=stub
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=
BREVO_API_KEY=

# App links for invite emails (optional)
APP_LOGIN_URL=
APP_REGISTER_URL=
FRONTEND_URL=
