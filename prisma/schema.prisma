generator client {
  provider = "prisma-client-js"
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  name             String?
  passwordHash     String
  createdAt        DateTime        @default(now())
  activities       Activity[]      @relation("ActivityActor")
  ownedBoards      Board[]         @relation("BoardOwner")
  boardMemberships BoardMember[]
  sentInvites      PendingInvite[] @relation("InviteSender")
}

model Board {
  id             String          @id @default(uuid())
  title          String
  description    String?
  visibility     BoardVisibility
  ownerId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  activities     Activity[]
  owner          User?           @relation("BoardOwner", fields: [ownerId], references: [id])
  members        BoardMember[]
  columns        Column[]
  labels         Label[]
  pendingInvites PendingInvite[]
  statuses       Status[]
}

model BoardMember {
  boardId String
  userId  String
  role    BoardRole
  board   Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
}

model Column {
  id        String   @id @default(uuid())
  boardId   String
  title     String
  position  Int
  statusId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([boardId, position])
}

model Task {
  id               String        @id @default(uuid())
  columnId         String
  title            String
  description      String?
  priority         TaskPriority?
  dueDate          DateTime?
  assigneeId       String?
  position         Int
  statusId         String?
  overrideStatusId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  column           Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)
  taskLabels       TaskLabel[]

  @@index([columnId, position])
}

model Label {
  id         String      @id @default(uuid())
  boardId    String
  name       String
  color      String?
  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  taskLabels TaskLabel[]
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Status {
  id      String  @id @default(uuid())
  boardId String
  name    String
  order   Int
  color   String?
  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model Activity {
  id         String             @id @default(uuid())
  actorId    String
  boardId    String
  entityType ActivityEntityType
  entityId   String
  action     ActivityAction
  diff       String?
  createdAt  DateTime           @default(now())
  actor      User               @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  board      Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@index([entityType, entityId])
}

model PendingInvite {
  id              String       @id @default(uuid())
  boardId         String
  email           String
  role            BoardRole
  invitedByUserId String
  createdAt       DateTime     @default(now())
  status          InviteStatus @default(PENDING)
  acceptedAt      DateTime?
  emailSentAt     DateTime?
  board           Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  invitedBy       User         @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([boardId, email, status])
  @@index([email, status])
}

enum BoardVisibility {
  PUBLIC
  PRIVATE
}

enum BoardRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityEntityType {
  TASK
  COLUMN
  BOARD
}

enum ActivityAction {
  CREATE
  UPDATE
  MOVE
  DELETE
}

enum InviteStatus {
  PENDING
  ACCEPTED
}
